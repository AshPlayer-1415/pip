{
  "name": "winsy-ai",
  "productName": "Winsy AI",
  "version": "0.4.0",
  "description": "A local-first macOS assistant companion for reminders, quick storage, and desktop actions.",
  "main": "src/main.js",
  "author": "Winsy AI",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac dmg"
  },
  "build": {
    "appId": "com.winsyai.desktop",
    "productName": "Winsy AI",
    "executableName": "Winsy AI",
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "darkModeSupport": true,
      "hardenedRuntime": true
    },
    "dmg": {
      "backgroundColor": "#111217",
      "window": {
        "width": 540,
        "height": 380
      }
    }
  },
  "devDependencies": {
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3"
  }
}
